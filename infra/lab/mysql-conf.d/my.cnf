# ============================================================
# DeepSecurity Lab — MySQL 自定义配置
# 挂载到 /etc/mysql/conf.d/
# ============================================================

[mysqld]
# 日志配置（安全审计用途）
general_log_file       = /var/log/mysql/general.log
general_log            = 1
slow_query_log_file    = /var/log/mysql/slow.log
slow_query_log         = 1
long_query_time        = 2
log_error              = /var/log/mysql/error.log

# 连接限制
max_connections        = 100
